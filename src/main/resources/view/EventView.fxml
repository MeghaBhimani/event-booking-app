<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="450" prefWidth="700" spacing="15" style="-fx-background-color: #fff0f5;" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EventViewController">

    <!-- Event Title -->
    <Label fx:id="titleLabel" style="-fx-font-size: 22px; -fx-font-weight: bold;" textFill="#663399" wrapText="true" />

    <!-- Event Details -->
    <Label fx:id="venueLabel" style="-fx-font-size: 14px;" />
    <Label fx:id="dayLabel" style="-fx-font-size: 14px;" />
    <Label fx:id="priceLabel" style="-fx-font-size: 14px;" />
    <Label fx:id="availableSeatsLabel" style="-fx-font-size: 14px;" />

    <!-- Quantity and Add to Cart -->
    <HBox alignment="CENTER" spacing="10">
        <TextField fx:id="quantityField" prefWidth="80" promptText="Quantity" />
        <Button fx:id="addToCartButton" onAction="#handleAddToCart" style="-fx-background-color:  #663399FF;" text="Add to Cart" textFill="beige" />
    </HBox>

    <!-- Back Button -->
    <Button fx:id="backButton" maxWidth="100" onAction="#handleBack" style="-fx-background-color:  #663399FF;" text="Back" textFill="beige" />

    <!-- Status Label -->
    <Label fx:id="statusLabel" alignment="CENTER" maxWidth="580" textFill="red" wrapText="true" />

</VBox>
